# Frontend Environment Variables for Vercel Deployment

# Backend API URL - Set this to your deployed backend URL
# This is only needed for local development
# In production, the Next.js API routes will proxy requests to the backend
# Examples:
#   - Render: https://your-app-name.onrender.com
#   - Railway: https://your-app-name.up.railway.app
#   - Fly.io: https://your-app-name.fly.dev
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Enable demo mode for development
NEXT_PUBLIC_DEMO_MODE=false

# Optional: Analytics and monitoring
NEXT_PUBLIC_GA_ID=your-google-analytics-id
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com
